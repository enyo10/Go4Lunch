<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".controllers.activities.WelcomeActivity"
    tools:showIn="@layout/app_bar_welcome">


    <android.support.v4.view.ViewPager
        android:id="@+id/activity_main_view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />


    <!-- 1 | Add TabLayout to handle tabs -->
    <android.support.design.widget.TabLayout
        android:id="@+id/activity_main_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/browser_actions_bg_grey"
        app:tabIndicatorColor="@android:color/holo_green_light"
        app:tabIndicatorHeight="5dp"
        app:tabSelectedTextColor="@color/baseColor"
        app:tabIconTintMode="src_in"
        app:tabTextColor="@android:color/black" />



</LinearLayout>